{
   "action": {
      "default_popup": "popup.html",
      "default_title": "Auto Refresh Plus"
   },
   "author": "Auto Refresh Plus",
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "content-scripts/arp.js", "content-scripts/script.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_start",
      "world": "ISOLATED"
   } ],
   "default_locale": "en",
   "description": "__MSG_app_description__",
   "externally_connectable": {
      "matches": [ "*://*/*" ]
   },
   "homepage_url": "https://poomainthan.vercel.app",
   "icons": {
      "128": "icon/128.png",
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "96": "icon/96.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Auto Refresh Plus | Page Monitor",
   "optional_host_permissions": [ "http://*/*", "https://*/*" ],
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "notifications", "tabs", "storage", "unlimitedStorage", "contextMenus", "scripting", "alarms", "webRequest", "cookies", "sidePanel", "offscreen", "power" ],
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "9.1.5",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "assets/*", "content-scripts/*", "_locales/*" ]
   }, {
      "matches": [ "*://*/*" ],
      "resources": [ "content-scripts/script.css" ],
      "use_dynamic_url": true
   } ]
}
